{
    "jsc": {
    "parser": {
    "syntax": "typescript",
    "tsx": false,
    "dynamicImport": false,
    "decorators": true
    },
    "transform": {
        "legacyDecorator": true,
        "decoratorMetadata": true
    },
    "target": "es5",
    "loose": false,
    "externalHelpers": false,
    "keepClassNames": false
    },
    "minify": false
   }
   